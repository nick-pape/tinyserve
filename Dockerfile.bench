FROM nvidia/cuda:12.8.0-devel-ubuntu24.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
        python3.12 python3-pip python3-dev build-essential \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY third_party/ ./third_party/
COPY pyproject.toml README.md LICENSE build_ggml.py ./
COPY tinyserve/ ./tinyserve/

RUN pip install --no-cache-dir --break-system-packages ".[server,gpu,progress]"

# Stock install pulls torch 2.11+cu13 — requires NVIDIA driver 580+.
# Host runs driver 570 / CUDA 12.8, so override to the cu128 wheel.
RUN pip install --no-cache-dir --break-system-packages --upgrade \
        --index-url https://download.pytorch.org/whl/cu128 torch

# accelerate is required by load_and_offload / load_from_gguf but not declared in pyproject.
# kernels is required for transformers MXFP4 dequant (gpt-oss family) — without it
# transformers silently falls back to BF16, blowing up VRAM ~4×.
RUN pip install --no-cache-dir --break-system-packages accelerate "kernels>=0.12.0"

# flash-linear-attention + causal-conv1d are required for Qwen3.5MoE / Qwen3.6 GatedDeltaNet
# to use fused CUDA kernels. Without them transformers logs
#   "The fast path is not available because one of the required library is not installed.
#    Falling back to torch implementation."
# and chunk_gated_delta_rule / causal_conv1d_update run in pure PyTorch — ~50-100× slower,
# dominating decode time (we measured 0.10 tok/s on a 40-layer Qwen3.6 model with the fallback).
#
# flash-linear-attention is pure-Python (Triton JIT) so installs easily.
# causal-conv1d compiles CUDA kernels from source: use --no-build-isolation so it
# picks up our cu128 torch (otherwise pip's isolated build env pulls a fresh cu13
# torch and the CUDA-version check fails: system has 12.8, isolated has 13.0).
# TORCH_CUDA_ARCH_LIST="12.0" targets Blackwell sm_120 specifically.
RUN pip install --no-cache-dir --break-system-packages \
        ninja packaging setuptools wheel \
    && pip install --no-cache-dir --break-system-packages flash-linear-attention \
    && TORCH_CUDA_ARCH_LIST="12.0" \
       pip install --no-cache-dir --break-system-packages --no-build-isolation \
           causal-conv1d

ENV HF_HOME=/cache/hf-shared
ENV TORCHINDUCTOR_CACHE_DIR=/cache/tinyserve-inductor

EXPOSE 8000
